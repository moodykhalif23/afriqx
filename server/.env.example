# Copy to .env and adjust. Loaded automatically on startup if present.

# HTTP
PORT=8080
# Comma-separated list of allowed CORS origins (the Vite dev server, etc.)
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Postgres
DATABASE_URL=postgres://afriqx:afriqx@localhost:5432/afriqx?sslmode=disable

# Auth
JWT_SECRET=dev-secret-change-me-in-production
JWT_TTL=24h

# Live market engine tick interval
TICK_INTERVAL=2s

# Seed a demo user on first run (email/password). Leave blank to skip.
SEED_USER_EMAIL=amara@afriqx.africa
SEED_USER_PASSWORD=afriqx123
SEED_USER_NAME=Amara Okafor
