# HTTP
PORT=8080
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Postgres — host port 5433 matches docker-compose.yml
DATABASE_URL=postgres://afriqx:afriqx@localhost:5433/afriqx?sslmode=disable

# Auth — REQUIRED. Generate a strong secret, e.g. `openssl rand -hex 32`.
JWT_SECRET=
JWT_TTL=24h

# Live market engine tick interval
TICK_INTERVAL=2s

# Demo user — seeded on first run ONLY when both email and password are set.
SEED_USER_EMAIL=
SEED_USER_PASSWORD=
SEED_USER_NAME=Demo User
