# Frontend env. Copy to .env.local and adjust. All vars must be VITE_-prefixed.

# Base URL of the AFRIQX Go API.
VITE_API_URL=http://localhost:8080/api/v1

# Optional: override the WebSocket live-feed URL. If unset it is derived from
# VITE_API_URL (http->ws, https->wss) as <origin>/api/v1/ws.
# VITE_WS_URL=ws://localhost:8080/api/v1/ws
